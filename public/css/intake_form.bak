/* ==========================================================================
   Patient Intake Form — Stylesheet
   MedCare Integrated Psychiatric & Lifestyle Medicine Clinic
   ========================================================================== */

/* Page Layout */
body {
  margin: 0;
  font-family: 'Segoe UI', system-ui, sans-serif;
  background: linear-gradient(135deg, #eff6ff 0%, #ffffff 50%, #f0fdf4 100%);
  min-height: 100vh;
  color: #111827;
}

.kiosk-page {
  max-width: 896px;
  margin: 0 auto;
  padding: 2rem 1rem;
}

@media (min-width: 768px) {
  .kiosk-page {
    padding: 3rem 2rem;
  }
}

/* Typography */
.form-header h1 {
  font-size: 2rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 0.5rem;
}

.form-header p {
  text-align: center;
  color: #6b7280;
  font-size: 1.125rem;
  margin-top: 0;
}

.step-heading h2 {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 0.25rem;
}

.step-heading p {
  margin-top: 0;
  color: #6b7280;
}

.step-heading.center {
  text-align: center;
}

.subsection h3 {
  font-size: 1.25rem;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 0.75rem;
}

.hint {
  font-size: 0.875rem;
  color: #6b7280;
}

/* Back to Home */
.back-home {
  margin-bottom: 1rem;
}

/* Progress Bar */
.progress-container {
  margin-bottom: 2rem;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0.5rem;
  font-size: 0.875rem;
}

.progress-track {
  height: 12px;
  background: #e5e7eb;
  border-radius: 9999px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #2563eb;
  border-radius: 9999px;
  transition: width 0.3s ease;
}

/* Form Card */
.form-card {
  background: white;
  border-radius: 1rem;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
  padding: 1.5rem;
}

@media (min-width: 768px) {
  .form-card {
    padding: 2.5rem;
  }
}

/* Step Panels */
.step-panel {
  display: none;
}

.step-panel.active {
  display: block;
}

/* Field Groups */
.field-group label {
  display: block;
  font-size: 1rem;
  font-weight: 500;
  margin-bottom: 0.5rem;
  color: #374151;
}

input[type="text"],
input[type="number"],
input[type="date"],
select,
textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem;
  padding: 0.75rem 1rem;
  font-size: 1.125rem;
  outline: none;
  font-family: inherit;
  color: #111827;
  background: white;
}

input[type="text"],
input[type="number"],
input[type="date"],
select {
  height: 3rem;
}

input[type="text"]:focus,
input[type="number"]:focus,
input[type="date"]:focus,
select:focus,
textarea:focus {
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

textarea {
  height: auto;
  resize: vertical;
  min-height: 6rem;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .field-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.field-group.full-width {
  grid-column: 1 / -1;
}

/* Checkboxes and Radio Rows */
.checkbox-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
}

@media (min-width: 768px) {
  .checkbox-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.checkbox-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  border: 1px solid #e5e7eb;
  border-radius: 0.5rem;
  cursor: pointer;
  transition: background 0.15s;
}

.checkbox-row:hover {
  background: #f9fafb;
}

.checkbox-row input[type="checkbox"],
.radio-row input[type="radio"] {
  width: 1.25rem;
  height: 1.25rem;
  accent-color: #2563eb;
  flex-shrink: 0;
}

.checkbox-row.sm {
  padding: 0.5rem;
}

.radio-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  border: 1px solid #e5e7eb;
  border-radius: 0.5rem;
  cursor: pointer;
  transition: background 0.15s;
}

.radio-row:hover {
  background: #f9fafb;
}

.radio-grid-4 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
}

@media (min-width: 768px) {
  .radio-grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

/* Expand/Collapse */
.expand-target {
  transition: max-height 0.3s ease, opacity 0.3s ease;
  margin-top: 0.75rem;
  padding-left: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.expand-target.hidden {
  display: none;
}

/* Trauma Cards / Substance Cards */
.trauma-card,
.substance-card {
  border: 2px solid #e5e7eb;
  border-radius: 0.75rem;
  padding: 1rem;
  margin-bottom: 1rem;
}

.trauma-toggle,
.substance-toggle {
  font-size: 1.125rem;
  font-weight: 600;
}

/* Lifestyle Cards */
.lifestyle-card {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 0.75rem;
  padding: 1.5rem;
  margin-bottom: 1.25rem;
}

.lifestyle-card.blue-gradient {
  background: linear-gradient(135deg, #eff6ff, #ffffff);
}

.lifestyle-card.green-gradient {
  background: linear-gradient(135deg, #f0fdf4, #ffffff);
}

.card-label {
  font-size: 1.125rem;
  font-weight: 600;
  display: block;
  margin-bottom: 0.5rem;
}

/* Sliders */
input[type="range"] {
  width: 100%;
  accent-color: #2563eb;
  height: 0.5rem;
  cursor: pointer;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.875rem;
  color: #6b7280;
  margin-top: 0.5rem;
}

.slider-value {
  font-size: 1.25rem;
  font-weight: 700;
  color: #2563eb;
}

/* PHQ Questions */
.phq-question {
  padding-bottom: 1rem;
  border-bottom: 1px solid #f3f4f6;
  margin-bottom: 1rem;
}

.phq-question:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.question-label {
  font-size: 1rem;
  font-weight: 500;
  display: block;
  margin-bottom: 0.75rem;
}

/* Summary Cards */
.summary-card {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 0.75rem;
  padding: 1.25rem;
  margin-bottom: 1rem;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.75rem;
}

.summary-header h3 {
  font-size: 1.125rem;
  font-weight: 600;
  margin: 0;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 0.5rem 0;
  border-bottom: 1px solid #f3f4f6;
  font-size: 0.875rem;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-row .label {
  color: #6b7280;
}

.summary-row .value {
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.25rem;
}

.badge {
  background: #dbeafe;
  color: #1e40af;
  padding: 0.25rem 0.5rem;
  border-radius: 0.375rem;
  font-size: 0.75rem;
}

/* Buttons */
.btn-primary {
  background: #2563eb;
  color: white;
  border: none;
  border-radius: 0.5rem;
  padding: 0.75rem 2rem;
  font-size: 1rem;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.15s;
}

.btn-primary:hover {
  background: #1d4ed8;
}

.btn-outline {
  background: transparent;
  color: #374151;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem;
  padding: 0.75rem 2rem;
  font-size: 1rem;
  cursor: pointer;
}

.btn-success {
  background: #16a34a;
  color: white;
  border: none;
  border-radius: 0.5rem;
  padding: 0.75rem 2rem;
  font-size: 1rem;
  cursor: pointer;
}

.btn-lg {
  font-size: 1.125rem;
  padding: 0.875rem 2.5rem;
}

.btn-outline-sm {
  background: transparent;
  border: 1px solid #d1d5db;
  border-radius: 0.375rem;
  padding: 0.375rem 0.75rem;
  font-size: 0.875rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.btn-ghost {
  background: none;
  border: none;
  color: #374151;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  text-decoration: none;
  width: fit-content;
}

.btn-ghost:hover {
  background: #f3f4f6;
}

/* Navigation Bar */
.form-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid #e5e7eb;
}

.hidden {
  display: none !important;
}

/* Notice and Privacy Cards */
.notice-card.blue {
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 0.75rem;
  padding: 1rem;
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
  margin-bottom: 1.25rem;
}

.notice-card.blue svg {
  flex-shrink: 0;
  margin-top: 0.125rem;
}

.notice-card.blue p {
  margin: 0.25rem 0 0;
}

.privacy-card {
  background: #f9fafb;
  border: 2px solid #e5e7eb;
  border-radius: 0.75rem;
  padding: 1.25rem;
}

.privacy-card h4 {
  margin-top: 0;
}

.form-footer {
  text-align: center;
  font-size: 0.875rem;
  color: #9ca3af;
  margin-top: 1.5rem;
}

/* Subsections */
.subsection {
  margin-bottom: 2rem;
}

.subsection.border-top {
  padding-top: 1.5rem;
  border-top: 1px solid #e5e7eb;
  margin-top: 1.5rem;
}

.expand-checkbox-group {
  margin-top: 0.75rem;
}